---
import Seo from '../components/Seo.astro';
import RevealScript from '../components/RevealScript.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: string;
	canonical?: string;
}

const { title, description, image, type, canonical } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		{/* Set the `js` flag before paint so reveal animations start hidden (no flash),
		    and resolve the theme (localStorage → OS preference → dark) to avoid a theme flash. */}
		<script is:inline>
			document.documentElement.className = 'js';
			try {
				var t = localStorage.getItem('ytalyze-theme');
				if (!t) t = matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
				if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
			} catch (e) {}
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/favicon.svg" />
		<link rel="preconnect" href="https://api.fontshare.com" crossorigin />
		<link
			href="https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&f[]=general-sans@400,500,600,700&display=swap"
			rel="stylesheet"
		/>
		<Seo
			title={title}
			description={description}
			image={image}
			type={type}
			canonical={canonical}
		/>
	</head>
	<body>
		<slot />
		<RevealScript />
	</body>
</html>
