---
import Seo from '../components/Seo.astro';
import RevealScript from '../components/RevealScript.astro';
import PostHog from '../components/posthog.astro';
import { defaultLocale, hreflang, type Locale } from '../i18n/ui';
import '../styles/global.css';

interface Props {
	locale?: Locale;
	title?: string;
	description?: string;
	image?: string;
	type?: string;
	canonical?: string;
}

const { locale = defaultLocale, title, description, image, type, canonical } = Astro.props;

// Only the English homepage carries the language auto-detect redirect.
const detectLanguage = locale === defaultLocale && Astro.url.pathname === '/';

// Browser-language detection: if the visitor's primary language is Portuguese,
// redirect once per session to /pt-br/. Runs before paint; `replace` keeps the
// back button usable, and the sessionStorage guard lets a pt user deliberately
// stay on `/`. The hash is preserved for anchor deep-links.
const detectScript = `(function () {
	try {
		if (sessionStorage.getItem('ytalyze-lang-redirected')) return;
		var lang = (navigator.languages && navigator.languages[0]) || navigator.language || '';
		if (lang.toLowerCase().indexOf('pt') === 0) {
			sessionStorage.setItem('ytalyze-lang-redirected', '1');
			location.replace('/pt-br/' + location.hash);
		}
	} catch (e) {}
})();`;
---

<!doctype html>
<html lang={hreflang[locale]}>
	<head>
		{detectLanguage && <script is:inline set:html={detectScript} />}
		{/* Set the `js` flag before paint so reveal animations start hidden (no flash),
		    and resolve the theme (localStorage → OS preference → dark) to avoid a theme flash. */}
		<script is:inline>
			document.documentElement.className = 'js';
			try {
				var t = localStorage.getItem('ytalyze-theme');
				if (!t) t = matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
				if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
			} catch (e) {}
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/favicon.svg" />
		<link rel="preconnect" href="https://api.fontshare.com" crossorigin />
		<link
			href="https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&f[]=general-sans@400,500,600,700&display=swap"
			rel="stylesheet"
		/>
		<Seo
			locale={locale}
			title={title}
			description={description}
			image={image}
			type={type}
			canonical={canonical}
		/>
		<PostHog />
	</head>
	<body>
		<slot />
		<RevealScript />
	</body>
</html>
