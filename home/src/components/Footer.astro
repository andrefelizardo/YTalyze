---
import { companyLinks, legalLinks, navLinks } from '../data/site';
import type { Dict } from '../i18n/ui';

interface Props {
	dict: Dict;
}

const { dict } = Astro.props;
const t = dict.footer;

const columns = [
	{
		title: t.columns.product,
		links: navLinks.map((link) => ({ href: link.href, label: dict.nav[link.key] })),
	},
	{
		title: t.columns.company,
		links: companyLinks.map((link) => ({ href: link.href, label: t.links[link.key] })),
	},
	{
		title: t.columns.legal,
		links: legalLinks.map((link) => ({ href: link.href, label: t.links[link.key] })),
	},
];
---

<footer class="ft">
	<div class="wrap">
		<div class="ft-grid">
			<div class="ft-brand">
				<a class="brand" href="#top" aria-label="YTalyze">
					<img src="/images/ytalyze-mark-white-color.svg" class="logo logo-dark" style="height:28px;" alt="YTalyze icon" />
					<img src="/images/ytalyze-mark-color.svg" class="logo logo-light" style="height:28px;" alt="" aria-hidden="true" />
					<span class="word">YTalyze</span>
				</a>
				<p>{t.tagline}</p>
			</div>
			<div class="ft-cols">
				{
					columns.map((col) => (
						<div class="ft-col">
							<h5>{col.title}</h5>
							{col.links.map((link) => (
								<a href={link.href}>{link.label}</a>
							))}
						</div>
					))
				}
			</div>
		</div>
		<div class="ft-bottom">
			<span class="mono">{t.copyright}</span>
			<span class="mono">{t.madeFor}</span>
		</div>
	</div>
</footer>
