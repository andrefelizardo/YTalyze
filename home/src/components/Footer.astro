---
import { footerColumns } from '../data/site';
---

<footer class="ft">
	<div class="wrap">
		<div class="ft-grid">
			<div class="ft-brand">
				<a class="brand" href="#top" aria-label="YTalyze">
					<img src="/images/ytalyze-mark-white-color.svg" class="logo" style="height:28px;" alt="YTalyze icon" />
					<span class="word">YTalyze</span>
				</a>
				<p>Rewind your watch history. One displaced frame, a whole history of you.</p>
			</div>
			<div class="ft-cols">
				{
					footerColumns.map((col) => (
						<div class="ft-col">
							<h5>{col.title}</h5>
							{col.links.map((link) => (
								<a href={link.href}>{link.label}</a>
							))}
						</div>
					))
				}
			</div>
		</div>
		<div class="ft-bottom">
			<span class="mono">© 2026 YTalyze · Not affiliated with YouTube or Google</span>
			<span class="mono">Made for the curious</span>
		</div>
	</div>
</footer>
