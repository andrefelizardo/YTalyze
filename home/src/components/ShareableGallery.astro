---
import ArrowIcon from './ArrowIcon.astro';

// Sample story cards (9:16). `num` may contain inline HTML for the unit.
const stories = [
	{ cls: 's1', idx: '01', k: 'Total watch time', num: '3,902<small>h</small>', d: '163 days of your life, pressed play. No regrets (some regrets).' },
	{ cls: 's2', idx: '02', k: 'Peak watch time', num: '12:47<small>AM</small>', d: 'Certified night owl. The mornings never stood a chance.' },
	{ cls: 's3', idx: '03', k: 'Your obsession', num: '312<small>vids</small>', d: 'One channel. 312 videos. A relationship, honestly.' },
	{ cls: 's4', idx: '04', k: 'Hours on cooking', num: '427<small>h</small>', d: "You could've gone to culinary school. You made toast." },
	{ cls: 's5', idx: '05', k: 'Rabbit holes', num: '38', d: 'Thirty-eight descents into the unknown. We counted them all.' },
];
---

<section class="share pad" id="share">
	<div class="glow"></div>
	<div class="wrap">
		<div class="sec-head reveal">
			<div class="lead">
				<span class="ey">Built to be posted</span>
				<h2>Every insight comes out<br />Story-shaped.</h2>
			</div>
			<p class="note">
				These are sample cards — yours generate from your own history. 9:16, bold, and ready
				to screenshot the second they load.
			</p>
		</div>
		<div class="gallery reveal" id="gallery">
			{
				stories.map((s) => (
					<div class:list={['story', s.cls]}>
						<div class="si">
							<div class="top"><span>YTalyze</span><span>{s.idx}</span></div>
							<div class="mid">
								<div class="k">{s.k}</div>
								<div class="num" set:html={s.num} />
								<div class="d">{s.d}</div>
								<div class="foot"><span>YTalyze</span><span>Sample</span></div>
							</div>
						</div>
					</div>
				))
			}
		</div>
		<div class="share-hint reveal">
			<ArrowIcon size={15} strokeWidth={2} />Drag to browse the set
		</div>
		<div class="share-actions reveal">
			<span class="chipbtn">
				<svg
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path>
					<path d="M16 6l-4-4-4 4M12 2v14"></path>
				</svg>Save all cards
			</span>
			<span class="chipbtn">
				<svg
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<circle cx="18" cy="5" r="3"></circle>
					<circle cx="6" cy="12" r="3"></circle>
					<circle cx="18" cy="19" r="3"></circle>
					<path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"></path>
				</svg>Post to Stories
			</span>
			<span class="chipbtn">
				<svg
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<rect x="3" y="3" width="18" height="18" rx="4"></rect>
					<path d="M8 12h8M12 8v8"></path>
				</svg>Make your own
			</span>
		</div>
	</div>
</section>

<script>
	// shareable gallery — drag / swipe to browse
	const g = document.getElementById('gallery');
	if (g) {
		let down = false;
		let moved = false;
		let startX = 0;
		let startScroll = 0;
		let pid: number | null = null;
		const DRAG_THRESHOLD = 4;

		g.addEventListener('pointerdown', (e) => {
			if (e.pointerType === 'mouse' && e.button !== 0) return;
			down = true;
			moved = false;
			pid = e.pointerId;
			startX = e.clientX;
			startScroll = g.scrollLeft;
			g.classList.add('grabbing');
		});

		g.addEventListener('pointermove', (e) => {
			if (!down) return;
			const dx = e.clientX - startX;
			if (!moved && Math.abs(dx) > DRAG_THRESHOLD) {
				moved = true;
				try {
					if (pid !== null) g.setPointerCapture(pid);
				} catch (_) {}
				g.style.scrollSnapType = 'none';
			}
			if (moved) {
				g.scrollLeft = startScroll - dx;
				e.preventDefault();
			}
		});

		function end() {
			if (!down || !g) return;
			down = false;
			g.classList.remove('grabbing');
			try {
				if (pid !== null) g.releasePointerCapture(pid);
			} catch (_) {}
			// restore snap on the next frame so the release position settles first
			requestAnimationFrame(() => {
				g.style.scrollSnapType = '';
			});
		}
		g.addEventListener('pointerup', end);
		g.addEventListener('pointercancel', end);
		g.addEventListener('pointerleave', end);

		// suppress click after a real drag (so chip taps inside don't fire on drag-release)
		g.addEventListener(
			'click',
			(e) => {
				if (moved) {
					e.stopPropagation();
					e.preventDefault();
					moved = false;
				}
			},
			true
		);

		// prevent native image/link dragging from hijacking the gesture
		g.addEventListener('dragstart', (e) => e.preventDefault());
	}
</script>
