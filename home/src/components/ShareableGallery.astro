---
import ArrowIcon from './ArrowIcon.astro';
import type { Dict } from '../i18n/ui';

interface Props {
	dict: Dict;
}

const { dict } = Astro.props;
const t = dict.shareGallery;

// Sample story cards (9:16) — structure here, localized text zipped in from
// `dict.shareGallery.stories` (same order). `numHtml` may contain inline HTML.
const stories = [
	{ cls: 's1', idx: '01' },
	{ cls: 's2', idx: '02' },
	{ cls: 's3', idx: '03' },
	{ cls: 's4', idx: '04' },
	{ cls: 's5', idx: '05' },
].map((s, i) => ({ ...s, ...t.stories[i] }));
---

<section class="share pad" id="share">
	<div class="glow"></div>
	<div class="wrap">
		<div class="sec-head reveal">
			<div class="lead">
				<span class="ey">{t.ey}</span>
				<h2 set:html={t.headingHtml} />
			</div>
			<p class="note">{t.note}</p>
		</div>
		<div class="gallery reveal" id="gallery">
			{
				stories.map((s) => (
					<div class:list={['story', s.cls]}>
						<div class="si">
							<div class="top"><span>YTalyze</span><span>{s.idx}</span></div>
							<div class="mid">
								<div class="k">{s.k}</div>
								<div class="num" set:html={s.numHtml} />
								<div class="d">{s.d}</div>
								<div class="foot"><span>YTalyze</span><span>{dict.hero.card.sample}</span></div>
							</div>
						</div>
					</div>
				))
			}
		</div>
		<div class="share-hint reveal">
			<ArrowIcon size={15} strokeWidth={2} />{t.hint}
		</div>
		<div class="share-actions reveal">
			<span class="chipbtn">
				<svg
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path>
					<path d="M16 6l-4-4-4 4M12 2v14"></path>
				</svg>{t.chips[0]}
			</span>
			<span class="chipbtn">
				<svg
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<circle cx="18" cy="5" r="3"></circle>
					<circle cx="6" cy="12" r="3"></circle>
					<circle cx="18" cy="19" r="3"></circle>
					<path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"></path>
				</svg>{t.chips[1]}
			</span>
			<span class="chipbtn">
				<svg
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<rect x="3" y="3" width="18" height="18" rx="4"></rect>
					<path d="M8 12h8M12 8v8"></path>
				</svg>{t.chips[2]}
			</span>
		</div>
	</div>
</section>

<script>
	// shareable gallery — drag / swipe to browse
	const g = document.getElementById('gallery');
	if (g) {
		let down = false;
		let moved = false;
		let startX = 0;
		let startScroll = 0;
		let pid: number | null = null;
		const DRAG_THRESHOLD = 4;

		g.addEventListener('pointerdown', (e) => {
			if (e.pointerType === 'mouse' && e.button !== 0) return;
			down = true;
			moved = false;
			pid = e.pointerId;
			startX = e.clientX;
			startScroll = g.scrollLeft;
			g.classList.add('grabbing');
		});

		g.addEventListener('pointermove', (e) => {
			if (!down) return;
			const dx = e.clientX - startX;
			if (!moved && Math.abs(dx) > DRAG_THRESHOLD) {
				moved = true;
				try {
					if (pid !== null) g.setPointerCapture(pid);
				} catch (_) {}
				g.style.scrollSnapType = 'none';
			}
			if (moved) {
				g.scrollLeft = startScroll - dx;
				e.preventDefault();
			}
		});

		function end() {
			if (!down || !g) return;
			down = false;
			g.classList.remove('grabbing');
			try {
				if (pid !== null) g.releasePointerCapture(pid);
			} catch (_) {}
			// restore snap on the next frame so the release position settles first
			requestAnimationFrame(() => {
				g.style.scrollSnapType = '';
			});
		}
		g.addEventListener('pointerup', end);
		g.addEventListener('pointercancel', end);
		g.addEventListener('pointerleave', end);

		// suppress click after a real drag (so chip taps inside don't fire on drag-release)
		g.addEventListener(
			'click',
			(e) => {
				if (moved) {
					e.stopPropagation();
					e.preventDefault();
					moved = false;
				}
			},
			true
		);

		// prevent native image/link dragging from hijacking the gesture
		g.addEventListener('dragstart', (e) => e.preventDefault());
	}
</script>
