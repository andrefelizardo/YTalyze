---
// The white "Get started" pill, reused in the nav, hero, and final CTA.
import ArrowIcon from './ArrowIcon.astro';

interface Props {
	label?: string;
	href?: string;
	withArrow?: boolean;
	class?: string;
}

const {
	label = 'Get started',
	href = '#',
	withArrow = false,
	class: className,
} = Astro.props;
---

<a href={href} class:list={['btn', 'btn-google', className]}>
	{label}
	{withArrow && <ArrowIcon class="gicon" />}
</a>
