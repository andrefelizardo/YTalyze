---
import type { Dict } from '../i18n/ui';

interface Props {
	dict: Dict;
}

const { dict } = Astro.props;
const t = dict.howItWorks;
---

<section class="how pad" id="how">
	<div class="wrap">
		<div class="sec-head reveal">
			<div class="lead">
				<span class="ey">{t.ey}</span>
				<h2 set:html={t.headingHtml} />
			</div>
			<p class="note">{t.note}</p>
		</div>
		<div class="steps">
			<div class="step reveal">
				<span class="n">01</span>
				<div class="ic">
					<svg viewBox="0 0 24 24" fill="none">
						<path
							d="M21 12.2c0-.66-.06-1.3-.17-1.9H12v3.6h5.05a4.32 4.32 0 0 1-1.87 2.84v2.36h3.02C19.96 17.45 21 15.05 21 12.2Z"
							fill="#fff"></path>
						<path
							d="M12 21.5c2.53 0 4.65-.84 6.2-2.27l-3.02-2.36c-.84.56-1.92.9-3.18.9-2.44 0-4.5-1.65-5.24-3.87H3.64v2.43A9.36 9.36 0 0 0 12 21.5Z"
							fill="#fff"></path>
						<path
							d="M6.76 13.9a5.62 5.62 0 0 1 0-3.6V7.87H3.64a9.4 9.4 0 0 0 0 8.46l3.12-2.43Z"
							fill="#fff"></path>
						<path
							d="M12 6.43c1.37 0 2.6.47 3.57 1.4l2.68-2.68C16.65 3.66 14.53 2.7 12 2.7a9.36 9.36 0 0 0-8.36 5.17l3.12 2.43C7.5 8.08 9.56 6.43 12 6.43Z"
							fill="#fff"></path>
					</svg>
				</div>
				<h3>{t.steps[0].title}</h3>
				<p>{t.steps[0].body}</p>
				<span class="ftag">{t.steps[0].ftag}</span>
			</div>
			<div class="step reveal">
				<span class="n">02</span>
				<div class="ic">
					<svg
						viewBox="0 0 24 24"
						fill="none"
						stroke="#fff"
						stroke-width="1.9"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M12 15V3"></path>
						<path d="m7 8 5-5 5 5"></path>
						<path d="M5 15v4a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-4"></path>
					</svg>
				</div>
				<h3>{t.steps[1].title}</h3>
				<p>{t.steps[1].body}</p>
				<span class="ftag">{t.steps[1].ftag}</span>
			</div>
			<div class="step reveal">
				<span class="n">03</span>
				<div class="ic">
					<svg
						viewBox="0 0 24 24"
						fill="none"
						stroke="#fff"
						stroke-width="1.9"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M3 13.5 9 9l4 3 5-6"></path>
						<path d="M3 20h18"></path>
						<path d="M3 4v16"></path>
					</svg>
				</div>
				<h3>{t.steps[2].title}</h3>
				<p>{t.steps[2].body}</p>
				<span class="ftag">{t.steps[2].ftag}</span>
			</div>
		</div>
	</div>
</section>
