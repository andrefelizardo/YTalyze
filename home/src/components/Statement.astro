---
import type { Dict } from '../i18n/ui';

interface Props {
	dict: Dict;
}

const { dict } = Astro.props;
const t = dict.statement;
---

<section class="statement pad">
	<div class="wrap">
		<span class="statement-ey reveal">{t.ey}</span>
		<h2 class="reveal" set:html={t.headingHtml} />
		<p class="reveal">{t.body}</p>
	</div>
</section>
