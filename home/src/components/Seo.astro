---
import { site } from '../data/site';
import { defaultLocale, getDict, hreflang, locales, type Locale } from '../i18n/ui';

interface Props {
	locale?: Locale;
	title?: string;
	description?: string;
	/** Path or absolute URL of the social card image. */
	image?: string;
	/** Open Graph type. */
	type?: string;
	/** Canonical path (relative to the site root). Defaults to the current path. */
	canonical?: string;
}

const { locale = defaultLocale, image = site.ogImage, type = 'website', canonical } = Astro.props;

const dict = getDict(locale);
const title = Astro.props.title ?? dict.meta.title;
const description = Astro.props.description ?? dict.meta.description;

// Build absolute URLs against the configured `site` so OG/canonical work for crawlers.
const base = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(canonical ?? Astro.url.pathname, base).href;
const imageURL = new URL(image, base).href;

// hreflang alternates — every page links both locale variants; x-default → English root.
const localeHome = (l: Locale) => new URL(l === defaultLocale ? '/' : `/${l}/`, base).href;
const alternates = locales.map((l) => ({ hreflang: hreflang[l], href: localeHome(l) }));
const otherOgLocales = locales.filter((l) => l !== locale).map((l) => getDict(l).meta.ogLocale);

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': new URL('#organization', base).href,
			name: site.name,
			url: base.href,
			logo: new URL('/favicon.svg', base).href,
		},
		{
			'@type': 'WebSite',
			'@id': new URL('#website', base).href,
			url: base.href,
			name: site.name,
			description,
			inLanguage: hreflang[locale],
			publisher: { '@id': new URL('#organization', base).href },
		},
		{
			'@type': 'SoftwareApplication',
			name: site.name,
			applicationCategory: 'UtilitiesApplication',
			operatingSystem: 'Web',
			description,
			inLanguage: hreflang[locale],
			url: base.href,
			offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
		},
	],
};
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta name="theme-color" content={site.themeColor} />

{/* hreflang alternates */}
{alternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
<link rel="alternate" hreflang="x-default" href={localeHome(defaultLocale)} />

{/* Open Graph */}
<meta property="og:type" content={type} />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={imageURL} />
<meta property="og:locale" content={dict.meta.ogLocale} />
{otherOgLocales.map((l) => <meta property="og:locale:alternate" content={l} />)}

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={site.twitter} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

{/* Structured data */}
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
