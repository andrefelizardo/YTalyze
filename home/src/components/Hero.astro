---
import WaitlistButton from './WaitlistButton.astro';
import type { Dict } from '../i18n/ui';

interface Props {
	dict: Dict;
}

const { dict } = Astro.props;
const t = dict.hero;
---

<section class="hero" id="top">
	<div class="glow"></div>
	<div class="wrap">
		<div class="hero-grid">
			<div class="hero-copy">
				<span class="eyebrow reveal">{t.eyebrow}</span>
				<h1 class="reveal">
					{t.h1Lead} <em class="grad-text pop">{t.h1Em}</em>
				</h1>
				<p class="hero-sub reveal">{t.sub}</p>
				<div class="hero-cta reveal">
					<WaitlistButton label={dict.joinWaitlist} withArrow source="hero" />
					<a href="#heart" class="btn btn-ghost">{t.readMore}</a>
				</div>
				<div class="hero-note reveal">
					{t.note.map((item) => <span>{item}</span>)}
				</div>
			</div>

			<div class="hero-stack reveal">
				<div class="ghost"></div>
				<div class="ghost b"></div>
				<div class="wcard">
					<div class="wc-shine"></div>
					<div class="inner">
						<div class="wc-top"><span>YTalyze</span><span>{t.card.sample}</span></div>
						<div class="wc-mid">
							<div class="wc-kicker">{t.card.kicker}</div>
							<div class="wc-num" set:html={t.card.numHtml} />
							<div class="wc-desc">{t.card.desc}</div>
						</div>
						<div class="wc-foot">
							<span class="yt">
								<img src="/images/ytalyze-mark-color.svg" width="15" height="17" alt="" />YTalyze
							</span>
							<span class="yr">{t.card.year}</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
