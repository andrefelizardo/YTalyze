---
interface Props {
	items: readonly string[];
}

const { items } = Astro.props;

// Duplicated track so the -50% translate loop is seamless.
const track = [...items, ...items];
---

<div class="ribbon" aria-hidden="true">
	<div class="marquee">
		{track.map((item) => <span>{item}</span>)}
	</div>
</div>
