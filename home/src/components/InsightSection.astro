---
import ArrowIcon from './ArrowIcon.astro';
import type { Insight } from '../data/insights';

interface Props {
	insight: Insight;
}

const { insight } = Astro.props;
const { theme, pill, tagline, heading, body, statNum, count, numStyle, statLabel, watermark, seekTop } =
	insight;
---

<section class:list={['insight', theme]}>
	<div class="seekband" style={`top:${seekTop};`}></div>
	<div class="watermark">{watermark}</div>
	<div class="wrap">
		<div class="insight-inner">
			<div class="main reveal">
				<span class="tagline"><span class="pill">{pill}</span> {tagline}</span>
				<h2 class="i-head">{heading}</h2>
				<p class="sub" set:html={body}></p>
				<div class="i-stat">
					<span class="i-num" data-count={count} style={numStyle} set:html={statNum}></span>
					<span class="i-lab">{statLabel}</span>
				</div>
				<a href="#top" class="insight-cta">Connect to see yours<ArrowIcon /></a>
			</div>
			<div class="aside reveal">
				<slot />
			</div>
		</div>
	</div>
</section>
