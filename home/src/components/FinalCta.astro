---
import WaitlistButton from './WaitlistButton.astro';
import type { Dict } from '../i18n/ui';

interface Props {
	dict: Dict;
}

const { dict } = Astro.props;
const t = dict.finalCta;
---

<section class="final pad">
	<div class="mesh"></div>
	<div class="wrap">
		<h2 class="reveal">{t.heading}</h2>
		<p class="reveal">{t.body}</p>
		<div class="hero-cta reveal">
			<WaitlistButton label={dict.joinWaitlist} withArrow />
			<a href="#top" class="btn btn-ghost">{t.backToTop}</a>
		</div>
		<div class="hero-note reveal" style="margin-top:22px;">
			{t.note.map((item) => <span>{item}</span>)}
		</div>
	</div>
</section>
