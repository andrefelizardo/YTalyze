---
import GetStartedButton from './GetStartedButton.astro';
---

<section class="final pad">
	<div class="mesh"></div>
	<div class="wrap">
		<h2 class="reveal">Ready to see yours?</h2>
		<p class="reveal">
			Get started and let YTalyze play your watch history back to you. Free, private,
			and ninety seconds from your first insight.
		</p>
		<div class="hero-cta reveal">
			<GetStartedButton withArrow />
			<a href="#top" class="btn btn-ghost">Back to top</a>
		</div>
		<div class="hero-note reveal" style="margin-top:22px;">
			<span>Free to run</span><span>No card required</span><span>Delete anytime</span>
		</div>
	</div>
</section>
