---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Hero from './Hero.astro';
import Marquee from './Marquee.astro';
import InsightSection from './InsightSection.astro';
import HowItWorks from './HowItWorks.astro';
import ShareableGallery from './ShareableGallery.astro';
import Trust from './Trust.astro';
import Statement from './Statement.astro';
import FinalCta from './FinalCta.astro';
import Footer from './Footer.astro';
import WaitlistModal from './WaitlistModal.astro';
import { insights } from '../data/insights';
import { getDict, type Locale } from '../i18n/ui';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const dict = getDict(locale);
const asides = dict.heartAsides;

// Bar widths for the watch-time glasscard (structural, zipped with localized rows).
const cookRows = asides.cook.rows.map((row, i) => ({ ...row, p: [1, 0.58, 0.43, 0.29][i] }));
---

<Layout locale={locale}>
	<Header dict={dict} />
	<main>
		<Hero dict={dict} />
		<Marquee items={dict.marquee} />

		{/* ===== HEART — history insights ===== */}
		<div id="heart"></div>

		{/* 1 · watch time */}
		<InsightSection insight={insights[0]} t={dict.insights[insights[0].theme]} cta={dict.insightCta}>
			<div class="glasscard">
				<div class="gc-k">{asides.cook.k}</div>
				<div class="gc-v">{asides.cook.v}</div>
				<div class="mbar" style="margin-top:16px;">
					{
						cookRows.map((row) => (
							<div class="row">
								<span>{row.label}</span><span class="track"><span class="fill" data-p={row.p}></span></span
								><span class="pct">{row.value}</span>
							</div>
						))
					}
				</div>
			</div>
		</InsightSection>

		{/* 2 · peak time */}
		<InsightSection insight={insights[1]} t={dict.insights[insights[1].theme]} cta={dict.insightCta}>
			<div class="glasscard">
				<div class="gc-k">{asides.night.k}</div>
				<div class="nightclock" id="nightClock" style="margin-top:14px;"></div>
				<div class="gc-row" style="margin-top:16px;"><span>{asides.night.afterMidnight}</span><span class="v">63%</span></div>
				<div class="gc-row"><span>{asides.night.beforeNine}</span><span class="v">4%</span></div>
			</div>
		</InsightSection>

		{/* 3 · rabbit holes — disabled; localized copy lives in dict.insights['b-hole'].
		    Re-enable with: <InsightSection insight={insights[2]} t={dict.insights[insights[2].theme]} cta={dict.insightCta}> */}
		<!-- <InsightSection insight={insights[2]} t={dict.insights[insights[2].theme]} cta={dict.insightCta}>
			<div class="glasscard">
				<div class="gc-k">Deepest single spiral</div>
				<div class="gc-v">89 videos</div>
				<div class="gc-row" style="margin-top:14px;"><span>Started</span><span class="v">11:02 PM</span></div>
				<div class="gc-row"><span>Surfaced</span><span class="v">4:19 AM</span></div>
				<div class="gc-row"><span>Topic</span><span class="v">Ancient Rome</span></div>
			</div>
		</InsightSection> -->

		{/* 4 · obsession — disabled */}
		<!-- <InsightSection insight={insights[3]} t={dict.insights[insights[3].theme]} cta={dict.insightCta}>
			<div class="glasscard">
				<div class="gc-k">Top channels · all time</div>
				<div class="mbar" style="margin-top:14px;">
					<div class="row">
						<span>Cosmic Kitchen</span><span class="track"
							><span class="fill" data-p="1"></span></span
						><span class="pct">312</span>
					</div>
					<div class="row">
						<span>Veritasium</span><span class="track"
							><span class="fill" data-p="0.61"></span></span
						><span class="pct">190</span>
					</div>
					<div class="row">
						<span>Lofi Girl</span><span class="track"
							><span class="fill" data-p="0.47"></span></span
						><span class="pct">147</span>
					</div>
					<div class="row">
						<span>MKBHD</span><span class="track"
							><span class="fill" data-p="0.33"></span></span
						><span class="pct">103</span>
					</div>
				</div>
			</div>
		</InsightSection> -->

		{/* 5 · taste shift — disabled */}
		<!-- <InsightSection insight={insights[4]} t={dict.insights[insights[4].theme]} cta={dict.insightCta}>
			<div class="glasscard">
				<div class="gc-k">Then → now</div>
				<div class="shiftpair" style="margin-top:14px;">
					<div class="chip"><div class="em">Gaming</div><div class="lab">2018</div></div>
					<div class="arrow"><ArrowIcon size={26} /></div>
					<div class="chip"><div class="em">Docs</div><div class="lab">2026</div></div>
				</div>
				<div class="gc-row" style="margin-top:16px;"><span>Genres explored</span><span class="v">7 eras</span></div>
				<div class="gc-row"><span>Biggest swing</span><span class="v">+340% docs</span></div>
			</div>
		</InsightSection> -->

		<HowItWorks dict={dict} />
		<ShareableGallery dict={dict} />
		<Trust dict={dict} />
		<Statement dict={dict} />
		<FinalCta dict={dict} />
	</main>
	<Footer dict={dict} />
	<WaitlistModal dict={dict} />
</Layout>

<script>
	// night sky dots (12a..11a, dim morning) for the "Peak time" insight
	const host = document.getElementById('nightClock');
	if (host) {
		const vals = [0.98, 0.92, 0.6, 0.34, 0.16, 0.08, 0.05, 0.04, 0.06, 0.1, 0.18, 0.28];
		vals.forEach((v) => {
			const i = document.createElement('i');
			const a = 0.12 + v * 0.88;
			i.style.background =
				v > 0.4
					? `linear-gradient(135deg, rgba(255,177,61,${a}), rgba(255,107,61,${a}))`
					: `rgba(255,255,255,${0.08 + v * 0.4})`;
			host.appendChild(i);
		});
	}
</script>
