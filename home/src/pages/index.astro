---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProductPreview from '../components/ProductPreview.astro';
import Marquee from '../components/Marquee.astro';
import InsightSection from '../components/InsightSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ShareableGallery from '../components/ShareableGallery.astro';
import Trust from '../components/Trust.astro';
import Statement from '../components/Statement.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import ArrowIcon from '../components/ArrowIcon.astro';
import { insights } from '../data/insights';
---

<Layout>
	<Header />
	<main>
		<Hero />
		<ProductPreview />
		<Marquee />

		{/* ===== HEART — history insights ===== */}
		<div id="heart"></div>

		{/* 1 · watch time */}
		<InsightSection insight={insights[0]}>
			<div class="glasscard">
				<div class="gc-k">Where the hours went</div>
				<div class="gc-v">Cooking &amp; food</div>
				<div class="mbar" style="margin-top:16px;">
					<div class="row">
						<span>Cooking</span><span class="track"><span class="fill" data-p="1"></span></span
						><span class="pct">427h</span>
					</div>
					<div class="row">
						<span>Tech</span><span class="track"><span class="fill" data-p="0.58"></span></span
						><span class="pct">248h</span>
					</div>
					<div class="row">
						<span>Music</span><span class="track"><span class="fill" data-p="0.43"></span></span
						><span class="pct">183h</span>
					</div>
					<div class="row">
						<span>Gaming</span><span class="track"><span class="fill" data-p="0.29"></span></span
						><span class="pct">124h</span>
					</div>
				</div>
			</div>
		</InsightSection>

		{/* 2 · peak time */}
		<InsightSection insight={insights[1]}>
			<div class="glasscard">
				<div class="gc-k">When you watch · 12a → 11a</div>
				<div class="nightclock" id="nightClock" style="margin-top:14px;"></div>
				<div class="gc-row" style="margin-top:16px;"><span>After midnight</span><span class="v">63%</span></div>
				<div class="gc-row"><span>Before 9 AM</span><span class="v">4%</span></div>
			</div>
		</InsightSection>

		{/* 3 · rabbit holes */}
		<InsightSection insight={insights[2]}>
			<div class="glasscard">
				<div class="gc-k">Deepest single spiral</div>
				<div class="gc-v">89 videos</div>
				<div class="gc-row" style="margin-top:14px;"><span>Started</span><span class="v">11:02 PM</span></div>
				<div class="gc-row"><span>Surfaced</span><span class="v">4:19 AM</span></div>
				<div class="gc-row"><span>Topic</span><span class="v">Ancient Rome</span></div>
			</div>
		</InsightSection>

		{/* 4 · obsession */}
		<InsightSection insight={insights[3]}>
			<div class="glasscard">
				<div class="gc-k">Top channels · all time</div>
				<div class="mbar" style="margin-top:14px;">
					<div class="row">
						<span>Cosmic Kitchen</span><span class="track"
							><span class="fill" data-p="1"></span></span
						><span class="pct">312</span>
					</div>
					<div class="row">
						<span>Veritasium</span><span class="track"
							><span class="fill" data-p="0.61"></span></span
						><span class="pct">190</span>
					</div>
					<div class="row">
						<span>Lofi Girl</span><span class="track"
							><span class="fill" data-p="0.47"></span></span
						><span class="pct">147</span>
					</div>
					<div class="row">
						<span>MKBHD</span><span class="track"
							><span class="fill" data-p="0.33"></span></span
						><span class="pct">103</span>
					</div>
				</div>
			</div>
		</InsightSection>

		{/* 5 · taste shift */}
		<InsightSection insight={insights[4]}>
			<div class="glasscard">
				<div class="gc-k">Then → now</div>
				<div class="shiftpair" style="margin-top:14px;">
					<div class="chip"><div class="em">Gaming</div><div class="lab">2018</div></div>
					<div class="arrow"><ArrowIcon size={26} /></div>
					<div class="chip"><div class="em">Docs</div><div class="lab">2026</div></div>
				</div>
				<div class="gc-row" style="margin-top:16px;"><span>Genres explored</span><span class="v">7 eras</span></div>
				<div class="gc-row"><span>Biggest swing</span><span class="v">+340% docs</span></div>
			</div>
		</InsightSection>

		<HowItWorks />
		<ShareableGallery />
		<Trust />
		<Statement />
		<FinalCta />
	</main>
	<Footer />
</Layout>

<script>
	// night sky dots (12a..11a, dim morning) for the "Peak time" insight
	const host = document.getElementById('nightClock');
	if (host) {
		const vals = [0.98, 0.92, 0.6, 0.34, 0.16, 0.08, 0.05, 0.04, 0.06, 0.1, 0.18, 0.28];
		vals.forEach((v) => {
			const i = document.createElement('i');
			const a = 0.12 + v * 0.88;
			i.style.background =
				v > 0.4
					? `linear-gradient(135deg, rgba(255,177,61,${a}), rgba(255,107,61,${a}))`
					: `rgba(255,255,255,${0.08 + v * 0.4})`;
			host.appendChild(i);
		});
	}
</script>
